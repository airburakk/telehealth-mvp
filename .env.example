# Postgres (Neon) bağlantıları
# Pooled (uygulama çalışma zamanı — Vercel'de bunu kullanın):
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
# Direct (migration / db push — yalnız CLI; Vercel runtime'da gerekmez):
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# Oturum imzalama anahtarı (üretimde: openssl rand -base64 32)
SESSION_SECRET="change-me-to-a-long-random-secret"

# Claude (Anthropic) API — gerçek AI triyaj için. Anahtar yoksa sistem otomatik
# olarak kural tabanlı triyaj motoruna düşer (uygulama yine çalışır).
# Anahtarı https://console.anthropic.com adresinden alın; Vercel'de de env olarak ekleyin.
ANTHROPIC_API_KEY="sk-ant-..."
