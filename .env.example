# Veritabanı bağlantısı
# Yerel geliştirme (SQLite):   DATABASE_URL="file:./dev.db"
# Üretim (Postgres / Neon):    DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
DATABASE_URL="file:./dev.db"

# Oturum imzalama anahtarı (rastgele uzun bir değer üretin)
# Üretim: `openssl rand -base64 32` çıktısını kullanın
SESSION_SECRET="change-me-to-a-long-random-secret"
