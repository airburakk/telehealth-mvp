# Postgres (Neon) bağlantıları
# Pooled (uygulama çalışma zamanı — Vercel'de bunu kullanın):
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
# Direct (migration / db push — yalnız CLI; Vercel runtime'da gerekmez):
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# Oturum imzalama anahtarı — üretimde ZORUNLU + güçlü olmalı (openssl rand -base64 32).
# ⚠️ T4: NODE_ENV=production'da eksik/varsayılan/<16 karakter ise uygulama BOOT'TA DURUR (forge
# edilebilir JWT'yi engeller). Deploy ÖNCESİ Vercel ortam değişkenine güçlü değer atayın.
SESSION_SECRET="change-me-to-a-long-random-secret"

# Veri şifreleme ana anahtarı (KEK) — uygulama-katmanı at-rest şifreleme (E2EE Faz 1, lib/crypto.ts).
# Klinik kolonları (belge/transkript/SOAP/epikriz) AES-256-GCM envelope ile şifreler.
# Üret:  openssl rand -base64 32   (32 byte base64 olmalı)
# ⚠️ YEREL + ÜRETİM AYNI Neon DB → bu değer her ortamda (yerel .env + Vercel) AYNI olmalı; yoksa çapraz çözememe.
# ⚠️ ANAHTAR KAYBI = VERİ KAYBI → escrow/yedekle. Boşsa: yeni yazımlar düz metin kalır (dev), okuma bozulmaz.
DATA_ENCRYPTION_KEK=""

# Claude (Anthropic) API — gerçek AI triyaj için. Anahtar yoksa sistem otomatik
# olarak kural tabanlı triyaj motoruna düşer (uygulama yine çalışır).
# Anahtarı https://console.anthropic.com adresinden alın; Vercel'de de env olarak ekleyin.
ANTHROPIC_API_KEY="sk-ant-..."

# Web Push (PWA faz 2) — npx web-push generate-vapid-keys ile üretin
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:you@example.com"

# Gemini Live (gerçek zamanlı ses→ses çeviri, gemini-3.5-live-translate-preview)
# Google AI Studio'dan alın: https://aistudio.google.com/apikey · anahtar yoksa canlı tercüme dormant kalır
GEMINI_API_KEY=""

# WebRTC TURN relay (Metered) — farklı ağlardaki taraflar için video/ses relay'i (cross-network).
# https://metered.ca → ücretsiz katman · ikisi de yoksa STUN + OpenRelay demo'suna düşer.
METERED_API_KEY=""
METERED_DOMAIN=""

# Object storage (T11 — Vercel Blob) — PHI belgeleri (diploma/MMSS/lab/radyoloji/SO ekleri) base64
# olarak DB'de değil Blob'ta saklanır (bytes upload ÖNCESİ at-rest şifrelenir → Blob yalnız ciphertext).
# Kur: Vercel → Storage → Create Blob store → token'ı buraya VE Vercel env'e ekle (lib/storage.ts).
# ⚠️ BOŞSA: fallback olarak eski davranış (şifreli base64 DB'de) → çalışır ama satır şişer. Token gelince
#   yeni yüklemeler otomatik Blob'a gider; eski satırlar: npx tsx scripts/migrate-docs-to-blob.ts
BLOB_READ_WRITE_TOKEN=""

# (Opsiyonel) Triyaj modeli — boşsa varsayılan claude-sonnet-4-6.
# Örn. claude-opus-4-8 / claude-haiku-4-5. Maliyet/hacim kontrolü buradan.
TRIAGE_MODEL=""

# Google ile giriş/kayıt (M5 doktor sign up) — Google Cloud Console > OAuth 2.0 Client ID (Web).
# Yetkili yönlendirme URI'si: <origin>/api/auth/google/callback
#   (yerel: http://localhost:3000/api/auth/google/callback · üretim: https://<vercel-domain>/...).
# İkisi de boşsa "Google ile devam et" butonu DORMANT kalır ("Yakında"); e-posta kaydı yine çalışır.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
