# Postgres (Neon) bağlantıları
# Pooled (uygulama çalışma zamanı — Vercel'de bunu kullanın):
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
# Direct (migration / db push — yalnız CLI; Vercel runtime'da gerekmez):
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
# (Opsiyonel — YALNIZ TEST) Neon dev branch pooled bağlantısı: `npm run test:integration` + E2E buna karşı
# çalışır → prod'a ASLA yazmaz. Tanımsızsa entegrasyon süitleri atlanır (skipIf). ⚠️ Vercel'e EKLEME +
# `DATABASE_URL`'e karıştırma. Kurulum: tests/integration/README.md.
TEST_DATABASE_URL=""

# Oturum imzalama anahtarı — üretimde ZORUNLU + güçlü olmalı (openssl rand -base64 32).
# ⚠️ T4: NODE_ENV=production'da eksik/varsayılan/<16 karakter ise uygulama BOOT'TA DURUR (forge
# edilebilir JWT'yi engeller). Deploy ÖNCESİ Vercel ortam değişkenine güçlü değer atayın.
SESSION_SECRET="change-me-to-a-long-random-secret"

# Veri şifreleme ana anahtarı (KEK) — uygulama-katmanı at-rest şifreleme (E2EE Faz 1, lib/crypto.ts).
# Klinik kolonları (belge/transkript/SOAP/epikriz) AES-256-GCM envelope ile şifreler.
# Üret:  openssl rand -base64 32   (32 byte base64 olmalı)
# ⚠️ YEREL + ÜRETİM AYNI Neon DB → bu değer her ortamda (yerel .env + Vercel) AYNI olmalı; yoksa çapraz çözememe.
# ⚠️ ANAHTAR KAYBI = VERİ KAYBI → escrow/yedekle (DEPLOY.md "Yedekleme / Felaket Kurtarma"). Boşsa:
#   ÜRETİMDE yazım fail-closed (throw — düz-metin PHI yazılmaz, P0 #3); dev/test'te düz-metin passthrough.
DATA_ENCRYPTION_KEK=""

# İmzalı zaman damgası sırrı (simüle RFC 3161 TSA — lib/timestamp.ts; onam/audit kanıt token'ları HMAC'lenir).
# ⚠️ ÜRETİMDE ZORUNLU (SESSION_SECRET ile aynı desen): eksik/varsayılan/<16 karakter ise uygulama BOOT'TA
#   DURUR — deploy öncesi Vercel'de güçlü değer şart (yerel .env ile AYNI). Üret: openssl rand -base64 32.
#   Eski (sır öncesi) kayıtlar legacy dev-sırla doğrulanmaya devam eder (yanlış tamper alarmı yok).
#   Dev'de boşsa uyarı + eski fallback. (Gerçek harici TSA'ya geçiş = park borç.)
TSA_SECRET=""

# (Opsiyonel) Vercel Blob erişim düzeyi override'ı — lib/storage.ts. Varsayılan/boş = "private" (PHI için doğru;
#   dosyalar yalnız SDK token'lı get() ile okunur). "public" YALNIZ PHI-dışı içerik için; sağlık verisinde KULLANMA.
BLOB_ACCESS=""

# (Opsiyonel) Ably yönetilen realtime — WebRTC sinyalleşme birincil kanalı (lib/ably-server.ts).
# Anahtar YALNIZ sunucuda (istemci kanala-özel yalnız-subscribe token alır: /api/realtime/ably-token).
# Boşsa Ably devre dışı → sinyalleşme güvenle DB-poll yedeğiyle çalışır (kırılmaz, yalnız gecikme artar).
# ⚠️ TRANSKRİPT (PHI) Ably'ye GİTMEZ — yalnız offer/answer/ice/bye yayınlanır (transkript şifreli DB'de).
# Ably panelinden API anahtarını al (format appId.keyId:secret); Vercel'e de ekle (Production+Preview).
ABLY_API_KEY=""

# (Opsiyonel) Upstash Redis — DAĞITIK rate-limit (lib/rate-limit.ts; login/AI/paylaşım-şifre frenleri).
# Boşsa in-memory yedek çalışır (kırılmaz; serverless'ta instance-başına en-iyi-çaba). Upstash hatasında
# da otomatik in-memory'ye düşülür (fail-open — kesinti login'i kilitlemesin).
# Kur: console.upstash.com → Redis Database (Global/Frankfurt) → REST API bölümünden iki değeri kopyala;
# Vercel'e de ekle (Production+Preview, Sensitive). (Vercel Marketplace kurulumunda KV_REST_API_* adları
# da tanınır.)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Claude (Anthropic) API — gerçek AI triyaj için. Anahtar yoksa sistem otomatik
# olarak kural tabanlı triyaj motoruna düşer (uygulama yine çalışır).
# Anahtarı https://console.anthropic.com adresinden alın; Vercel'de de env olarak ekleyin.
ANTHROPIC_API_KEY="sk-ant-..."

# Web Push (PWA faz 2) — npx web-push generate-vapid-keys ile üretin
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:you@example.com"

# Gemini Live (gerçek zamanlı ses→ses çeviri, gemini-3.5-live-translate-preview)
# Google AI Studio'dan alın: https://aistudio.google.com/apikey · anahtar yoksa canlı tercüme dormant kalır
GEMINI_API_KEY=""

# WebRTC TURN relay — farklı ağlardaki taraflar için video/ses relay'i (cross-network).
# BİRİNCİL: Cloudflare Realtime TURN (dash.cloudflare.com → Realtime → TURN Keys; ücretsiz katman).
CF_TURN_KEY_ID=""
CF_TURN_API_TOKEN=""
# YEDEK: Metered (https://metered.ca) — Cloudflare yoksa/düşerse denenir.
# Hepsi boşsa STUN + OpenRelay demo'suna düşer (güvenilmez; üretimde cross-network çoğu zaman kopar).
METERED_API_KEY=""
METERED_DOMAIN=""

# Object storage (T11 — Vercel Blob) — PHI belgeleri (diploma/MMSS/lab/radyoloji/SO ekleri) base64
# olarak DB'de değil Blob'ta saklanır (bytes upload ÖNCESİ at-rest şifrelenir → Blob yalnız ciphertext).
# Kur: Vercel → Storage → Create Blob store → token'ı buraya VE Vercel env'e ekle (lib/storage.ts).
# ⚠️ BOŞSA: fallback olarak eski davranış (şifreli base64 DB'de) → çalışır ama satır şişer. Token gelince
#   yeni yüklemeler otomatik Blob'a gider; eski satırlar: npx tsx scripts/migrate-docs-to-blob.ts
BLOB_READ_WRITE_TOKEN=""

# (Opsiyonel) Triyaj modeli — boşsa varsayılan claude-sonnet-4-6.
# Örn. claude-opus-4-8 / claude-haiku-4-5. Maliyet/hacim kontrolü buradan.
TRIAGE_MODEL=""

# Google ile giriş/kayıt (M5 doktor sign up) — Google Cloud Console > OAuth 2.0 Client ID (Web).
# Yetkili yönlendirme URI'si: <origin>/api/auth/google/callback
#   (yerel: http://localhost:3000/api/auth/google/callback · üretim: https://<vercel-domain>/...).
# İkisi de boşsa "Google ile devam et" butonu DORMANT kalır ("Yakında"); e-posta kaydı yine çalışır.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Gunluk HealthTurkiye registry senkron cronu (vercel.json) icin koruma sirri.
# Vercel bu deger tanimliysa cron istegine otomatik "Authorization: Bearer" ekler.
CRON_SECRET=""

# WhatsApp / SMS bildirim kanali (FAZ 5, 2026-07-10) - DORMANT: bos birakilirsa gonderim
# simule edilir (log izi); saglayici hesabi acilinca doldurun (lib/messaging.ts aktivasyon noktasi).
WHATSAPP_API_TOKEN=""
WHATSAPP_PHONE_ID=""
SMS_API_KEY=""
SMS_SENDER_ID=""

# E-posta gonderimi + e-posta dogrulama (Auth Faz 5 / v5.6, lib/email.ts) - DORMANT: bos birakilirsa
# gonderim simule edilir VE yeni kayitlarda dogrulama zorunlulugu devreye GIRMEZ (bugunku akis surer).
# Aktivasyon: resend.com hesabi -> API Key -> RESEND_API_KEY; ozel domain'den gondermek icin Resend'de
# domain DNS dogrulamasi + EMAIL_FROM (or. "AURA <no-reply@ornek.com>"). EMAIL_FROM bossa Resend test
# gondericisi kullanilir (onboarding@resend.dev - yalniz hesap sahibinin adresine gonderir, test icindir).
# Etkinlesince: yeni e-posta kayitlari dogrulama baglantisi almadan giris yapamaz (mevcut hesaplar muaf;
# Google girisleri dogrulanmis sayilir). Vercel'e de ekleyin (Production+Preview, Sensitive).
RESEND_API_KEY=""
EMAIL_FROM=""
