// Telehealth MVP — veri şeması
// Kapsam: Triyaj + Doktor Paneli + Video görüşme iskeleti

generator client {
  provider      = "prisma-client-js"
  // Yerel: native · Vercel/Linux üretim: rhel-openssl-3.0.x
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // havuzlanmış (pooled) — uygulama çalışma zamanı
  directUrl = env("DIRECT_URL") // havuzsuz (direct) — migration / db push
}

/// Platform kullanıcısı (kimlik doğrulama + rol)
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         String // PATIENT, DOCTOR, COORDINATOR, ETHICS, ADMIN
  doctorId     String? // DOCTOR rolündeki kullanıcının hekim profili
  createdAt    DateTime @default(now())
}

/// KVKK/açık onam kaydı — kullanıcı bazlı, sürümlü (Consent Manager Faz 0).
/// Bir kez alınır; CONSENT_VERSION (lib/consent-config) artarsa kullanıcı bir kez yeniden onaylar.
/// scope ileride genişleyebilir (ör. ülkeye/işleme özel ayrı kapsamlar).
model ConsentRecord {
  id        String   @id @default(cuid())
  userId    String
  scope     String   @default("GENERAL_KVKK")
  version   Int
  grantedAt DateTime @default(now())
  ip        String?
  // İspat & bütünlük katmanı (RFC 3161 onam-ispat — dijital-onam-zaman-damgasi). Eski kayıtlar null (geriye dönük backfill yok).
  textHash    String? // onaylanan metnin (CONSENT_TEXT, o sürüm) SHA-256 hash'i
  userAgent   String? // cihaz / tarayıcı (User-Agent)
  channel     String  @default("WEB") // WEB | MOBILE | SMS_OTP ... (çok-kanallı onam)
  prevHash    String? // bir önceki kaydın entryHash'i (append-only hash-zinciri) — GENESIS=ilk
  entryHash   String? // SHA-256(userId|scope|version|textHash|ip|ua|grantedAt|prevHash) — bu kaydın mührü
  tsAuthority String? // zaman damgası otoritesi (şimdilik SIMULATED-LOCAL; üretim = RFC 3161 TSA — hukuk)
  tsTime      DateTime? // TSA'nın güvenilir zamanı
  tsToken     String? // imzalı zaman damgası token'ı (entryHash üzerinde)

  @@unique([userId, scope, version])
  @@index([userId])
}

/// Platformdaki uzman hekim
model Doctor {
  id            String         @id @default(cuid())
  name          String
  title         String // Prof. Dr., Doç. Dr., Op. Dr., Uzm. Dr.
  branch        String
  city          String
  languages     String // CSV: "Türkçe,Rusça,İngilizce"
  markets         String? // M5: hekimin hizmet verdiği pazarlar — CSV ISO kod "RU,DE,DZ" (boş = tümü)
  verified        Boolean        @default(true)
  bio             String?
  color           String         @default("#16467a")
  rating          Float          @default(4.7)
  successRate     Int            @default(95)
  experienceYears Int            @default(12)
  jci             Boolean        @default(true)
  capacity        Int            @default(20) // aylık işlem kapasitesi
  procedures      String? // M5: doktorun yaptığı işlemler + kendi fiyatı — JSON {"<kod>": <fiyat₺>}
  licenseNo       String? // FHIR Faz 0: hekim diploma/tescil no → Practitioner.identifier
  // Pro Bono — anlık müsaitlik + kontenjan (gönüllü ücretsiz konsültasyon)
  proBonoState       String    @default("OFFLINE") // OFFLINE | AVAILABLE | IN_SESSION
  proBonoQuota       Int       @default(10) // dönem (takvim haftası) başına kontenjan
  proBonoUsed        Int       @default(0)
  proBonoResetAt     DateTime? // kontenjan dönem başlangıcı
  proBonoAvailableAt DateTime? // en son AVAILABLE olunan an (eşleştirme sırası / stale tespiti)
  // Klinik nöbet/müsaitlik — 3-seçenek kapısı (§8 mahremiyet/akış): Branş online · İcapçı (icap) · Nöbetçi (7/24 genel)
  clinicalState       String    @default("OFFLINE") // OFFLINE | ONLINE | IN_SESSION — Branş/Nöbetçi gerçek-zaman klinik mevcudiyeti
  onCall              Boolean   @default(false) // İcapçı: offline ama randevu (icap) açık
  sentinel            Boolean   @default(false) // Nöbetçi yetkisi (7/24 genel/Dahiliye/Acil havuzu)
  clinicalAvailableAt DateTime? // en son ONLINE olma anı (eşleştirme sırası)
  cases           Case[]
  consultations   Consultation[]
  reviews         Review[]
  createdAt       DateTime       @default(now())
}

/// Doğrulanmış hasta yorumu (Modül 6)
model Review {
  id        String   @id @default(cuid())
  doctor    Doctor   @relation(fields: [doctorId], references: [id])
  doctorId  String
  author    String
  country   String
  stars     Int
  text      String
  createdAt DateTime @default(now())
}

/// Triyajdan geçen hasta vakası
model Case {
  id                  String         @id @default(cuid())
  userId              String? // vaka sahibi hasta (User.id) — hasta yalnız kendi vakalarını görür
  patientName         String
  country             String // DZ, LY, RU, KZ, KG, TR ...
  language            String
  // FHIR Faz 0: hasta stabil kimliği → Patient.identifier (içsel cuid korunur)
  patientIdentifier     String? // TC Kimlik / pasaport no (varsa)
  patientIdentifierType String? // "TC" | "PASSPORT" | ...
  symptoms            String
  durationText        String?
  extra               String? // branşa özel yanıtların JSON'u
  attachments         String? // CSV dosya adları
  branch              String
  urgency             Int // 1-5
  reasoning           String
  confidence          Int            @default(70) // 0-100
  status              String         @default("NEW") // NEW, IN_REVIEW, IN_CONSULT, DONE
  // Ön-konsültasyon ücret/sigorta kapısı (Modül 1)
  consultFee          Int? // tahsil edilen görüşme ücreti (USD)
  payStatus           String         @default("PENDING") // PENDING, PAID, INSURED
  payMethod           String? // PAYMENT | INSURANCE
  policyNo            String? // sigorta poliçe no (INSURANCE ise)
  payRef              String? // ödeme referansı (PAYMENT ise, simüle)
  // AI Epikriz / Taburcu Raporu — hastanın tüm yolculuğunun klinik döküman sentezi
  dischargeReport     String? // AI ile üretilen epikriz tam metni (başlık + bölümler)
  dischargeStructured String? // JSON: yapılandırılmış bölümler (tanı, anamnez, ...)
  dischargeAt         DateTime? // epikrizin oluşturulma zamanı
  icd10Code           String? // FHIR Faz 0: tanı ICD-10 kodu → Condition.code (kodlu; yoksa metin)
  labResults          String? // FHIR Faz 2: laboratuvar sonuçları JSON [{loinc,name,value,unit}] → Observation
  // M2→M3: doktorun görüşmede tavsiye ettiği tedaviler (KSHFT kodları + doktorun ₺ fiyatı)
  recommendedProcedures String? // JSON [{code,name,priceTRY}]
  // Pro Bono — ücretsiz konsültasyon akışı (mevcut Case yeniden kullanılır; normal vakada false/null)
  proBono             Boolean        @default(false)
  proBonoStatus       String? // WAITING|MATCHED|IN_CONSULT|CONSULT_DONE|TREATMENT_NEEDED|ETHICS_REVIEW|ETHICS_REJECTED|ETHICS_APPROVED|COMPLETED
  doctor              Doctor?        @relation(fields: [doctorId], references: [id])
  doctorId            String?
  consultations       Consultation[]
  bookings            Booking[]
  recovery            Recovery?
  complaints          Complaint[]
  shareLinks          ShareLink[]
  documents           CaseDocument[]
  createdAt           DateTime       @default(now())

  @@index([userId])
  @@index([proBono, proBonoStatus])
}

/// Hasta-doktor video görüşmesi
model Consultation {
  id        String    @id @default(cuid())
  case      Case      @relation(fields: [caseId], references: [id])
  caseId    String
  doctor    Doctor    @relation(fields: [doctorId], references: [id])
  doctorId  String
  notes     String    @default("")
  status    String    @default("ACTIVE") // ACTIVE, ENDED
  startedAt DateTime  @default(now())
  endedAt   DateTime?
}

/// İcapçı randevu akışı — "online doktor yoksa 3-seçenek kapısı" Seçenek 2 (§3.2 mahremiyet/akış).
/// Hasta "Branş randevusu" seçince oluşur; branştaki İcapçı hekimlere düşer, ilk teklif eden atomik
/// kapar (REQUESTED→OFFERED), hasta onay/değişiklik verir (SO Part B deseni). Case.id ile gevşek bağ
/// (plain String, FK yok → Case/Doctor modelleri değişmez). Onaylanınca mevcut /consult akışı yürütür.
model ConsultAppointment {
  id             String    @id @default(cuid())
  caseId         String    @unique // her vaka için tek aktif randevu akışı
  patientId      String? // vaka sahibi (User.id) — bildirim hedefi
  branch         String
  doctorId       String? // teklif veren İcapçı (Doctor.id)
  proposedAt     DateTime? // önerilen randevu zamanı (OFFERED)
  status         String    @default("REQUESTED") // REQUESTED | OFFERED | CONFIRMED | CHANGE_REQUESTED | CANCELLED
  consultationId String? // CONFIRMED + hasta katılınca oluşan Consultation.id
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([branch, status])
}

/// Sağlık turizmi paketi rezervasyonu (Modül 3)
model Booking {
  id                   String   @id @default(cuid())
  case                 Case     @relation(fields: [caseId], references: [id])
  caseId               String
  branch               String
  country              String
  tier                 String // Ekonomik, Standart, Premium
  hotelStars           Int
  hospitalType         String // Özel, Üniversite
  nights               Int
  translator           Boolean  @default(false)
  insuranceExtended    Boolean  @default(false)
  insuranceMalpractice Boolean  @default(false)
  subtotal             Int
  platformFee          Int
  total                Int
  currency             String   @default("USD")
  breakdown            String // JSON LineItem[]
  split                String // JSON LineItem[]
  status               String   @default("CONFIRMED") // DRAFT, CONFIRMED, CANCELLED
  escrowStatus         String   @default("HELD") // HELD, RELEASED, REFUNDED
  createdAt            DateTime @default(now())
}

/// Triyajda hastanın yüklediği tıbbi belge (tahlil/görüntüleme raporu/epikriz/reçete) — içerik + AI ön-değerlendirmesi.
/// İçerik base64 (küçük dosya; gerçek object storage TODO — SO/checkin deseni). DICOM görüntü içeriği saklanmaz
/// (viewer-only; radyoloji AI yorumu kapsam dışı). AI alanları doktor kokpitte "AI ile değerlendir & çevir" ile doldurulur.
model CaseDocument {
  id            String    @id @default(cuid())
  case          Case      @relation(fields: [caseId], references: [id])
  caseId        String
  label         String // dosya adı
  mimeType      String // application/pdf | image/jpeg | image/png | ...
  content       String? // base64 data URI — AI girdisi + orijinal görüntüleme (DICOM/büyük → null)
  // AI ön-değerlendirme (doktor başlatır; assessDocument çıktısı — hepsi Türkçe)
  aiDocType     String? // Laboratuvar | Görüntüleme Raporu | Epikriz / Tıbbi Rapor | Reçete | Diğer
  aiSummary     String? // klinik özet (önemli bulgular + triyaj şikayetiyle ilişki)
  aiTranslation String? // belge içeriğinin Türkçe çevirisi
  aiFlags       String? // anormal/kritik bulgu vurgusu (boş olabilir)
  assessedAt    DateTime?
  createdAt     DateTime  @default(now())

  @@index([caseId])
}

/// Post-Op iyileşme takibi (Modül 4)
model Recovery {
  id        String    @id @default(cuid())
  case      Case      @relation(fields: [caseId], references: [id])
  caseId    String    @unique
  branch    String
  status    String    @default("ACTIVE") // ACTIVE, COMPLETED
  startedAt DateTime  @default(now())
  checkIns  CheckIn[]
}

/// Günlük iyileşme kontrolü
model CheckIn {
  id         String   @id @default(cuid())
  recovery   Recovery @relation(fields: [recoveryId], references: [id])
  recoveryId String
  pain       Int // 0-10
  feverC     Float
  meds       Boolean  @default(true)
  note       String?
  photo      String?
  severity   String // NONE, WATCH, RED
  createdAt  DateTime @default(now())
}

/// WebRTC sinyalleşme mesajı (video görüşme — polling tabanlı)
model Signal {
  id             Int      @id @default(autoincrement())
  consultationId String
  sender         String // "doctor" | "patient"
  kind           String // "offer" | "answer" | "ice" | "bye"
  data           String // JSON
  createdAt      DateTime @default(now())

  @@index([consultationId])
}

/// Etik Kurul / Tahkim başvurusu (Modül 7)
model Complaint {
  id          String    @id @default(cuid())
  case        Case      @relation(fields: [caseId], references: [id])
  caseId      String
  bookingId   String? // ilgili rezervasyon (iade için)
  subject     String
  description String
  requestType String // REFUND, DOCTOR_CHANGE, HOSPITAL_CHANGE, OTHER
  evidence    String?
  status      String    @default("PENDING") // PENDING, RESOLVED
  // Kurul kararı
  verdict      String? // FAVOR, PARTIAL, REJECT
  action       String? // REFUND_FULL, REFUND_PARTIAL, SUPPLIER_CHANGE, ACCREDITATION_WARN, NONE
  refundAmount Int?
  rationale    String?
  decidedBy    String?
  decidedAt    DateTime?
  createdAt    DateTime  @default(now())
}

/// Güvenli dijital sağlık paylaşımı linki (Modül 4 — hasta kontrolünde veri paylaşımı)
/// Hasta, kendi verisini süreli/iptal edilebilir bir token-linki ile yurt dışındaki doktoruna paylaşır.
model ShareLink {
  id            String        @id @default(cuid())
  token         String        @unique // URL token — girişsiz erişim anahtarı
  case          Case          @relation(fields: [caseId], references: [id])
  caseId        String
  recipientName String? // hastanın girdiği alıcı adı, ör. "Dr. Smith" (ops.)
  scopes        String // CSV kategori: EPIKRIZ,RADYOLOJI,LAB,GORUSME_NOTU
  expiresAt     DateTime? // null = süresiz
  passwordHash  String? // opsiyonel erişim şifresi (bcrypt)
  allowDownload Boolean       @default(false)
  revokedAt     DateTime? // iptal edildiyse zaman damgası
  accesses      ShareAccess[]
  createdAt     DateTime      @default(now())

  @@index([caseId])
}

/// Uygulama içi bildirim — rol hedefli (yayın) VEYA kullanıcı hedefli (kişisel)
model Notification {
  id        String    @id @default(cuid())
  role      String? // hedef rol: PATIENT, DOCTOR, COORDINATOR, ETHICS, ADMIN (yayın)
  userId    String? // hedef kullanıcı (kişisel — vaka sahibi hasta vb.)
  type      String // NEW_CASE, RED_FLAG, BOOKING, COMPLAINT, DECISION, SHARE_ACCESS
  title     String
  body      String?
  href      String? // tıklayınca gidilecek sayfa
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([role, readAt])
  @@index([userId, readAt])
}

/// Arayüz çeviri önbelleği — TR kaynak metin → hedef dil (Claude ile bir kez çevrilir, sonsuza dek cache)
model Translation {
  id         String   @id @default(cuid())
  lang       String // hedef dil (Türkçe adıyla: "Rusça", "Arapça", ...)
  sourceHash String // sha1(kaynak) — uzun metinler için anahtar
  source     String // Türkçe kaynak metin
  translated String // çeviri
  createdAt  DateTime @default(now())

  @@unique([lang, sourceHash])
}

/// Web Push aboneliği — kullanıcının cihazı (tarayıcı kapalıyken bildirim)
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String // abone kullanıcı
  role      String // abonelik anındaki rol (rol yayını hedeflemesi)
  endpoint  String   @unique // push servisi adresi (FCM/APNs/Mozilla)
  p256dh    String // istemci açık anahtarı
  auth      String // kimlik doğrulama sırrı
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([role])
}

/// Paylaşım linkine erişim kaydı — Denetim İzi (Audit Trail)
model ShareAccess {
  id            String    @id @default(cuid())
  shareLink     ShareLink @relation(fields: [shareLinkId], references: [id])
  shareLinkId   String
  action        String // VIEW, DOWNLOAD
  ip            String?
  userAgent     String?
  detail        String? // indirilen dosya adı vb.
  seenByPatient Boolean   @default(false) // hasta erişim bildirimini gördü mü
  createdAt     DateTime  @default(now())

  @@index([shareLinkId])
}

/// ───────────────────────────────────────────────────────────────────────────
/// İkinci Görüş (Second Opinion) Modülü — boundary spec §4 (state machine) / §6
/// Mevcut genel triyaj akışından BAĞIMSIZ paralel akış. Kesişen altyapı
/// (auth, Notification, video Consultation, Translation, audit deseni) reuse edilir.
/// patientId / assignedDoctorId — Case.userId deseni gibi gevşek bağ (plain String,
/// FK relation YOK → User/Doctor modelleri değiştirilmez). Durum/tip string'leri
/// lib/second-opinion + data/second-opinion-docs ile eşleşir.
/// ───────────────────────────────────────────────────────────────────────────

/// Tek bir ikinci görüş talebi = bir vaka (§1). 11-durumlu yaşam döngüsü (§4).
model SecondOpinionCase {
  id               String  @id @default(cuid())
  patientId        String // vaka sahibi hasta (User.id)
  branch           String // 30 branştan biri (lib/triage BRANCHES.key)
  diagnosisSummary String // hastanın mevcut tanı özeti (serbest metin)
  country          String? // hasta ülkesi (COUNTRIES.code) — veri ikametgâhı/yönlendirme sinyali (geo-routing)
  language         String? // hastanın tercih ettiği iletişim dili (LANGUAGES) — eşleştirme + sunum dili
  status           String  @default("DRAFT") // bkz. lib/second-opinion SO_STATUSES
  assignedDoctorId String? // atanan hekim (Doctor.id) — §10: tek doktor
  // SLA zaman damgaları — hesap TEK KAYNAK lib/second-opinion (§11)
  consentAt          DateTime? // KVKK açık rıza (§8) — başvuru başında alınır
  paidAt             DateTime? // peşin ödeme onayı
  readyAt            DateTime? // READY_FOR_ASSIGNMENT — yazılı rapor SLA başlangıcı
  assignedAt         DateTime?
  opinionDeliveredAt DateTime? // video penceresi (15 gün) başlangıcı
  closedAt           DateTime?
  cancelledAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  documents   SecondOpinionDocument[]
  requests    SecondOpinionRequest[]
  opinion     SecondOpinion?
  appointment SecondOpinionAppointment?
  payment     SecondOpinionPayment?
  events      SecondOpinionEvent[]

  @@index([patientId])
  @@index([assignedDoctorId])
  @@index([status])
}

/// Vakaya bağlı tıbbi belge (§6, §6.5). DICOM (IMAGING) harici link olarak tutulur;
/// diğerleri küçük dosya → base64 (gerçek object storage TODO, §8/§9.2).
model SecondOpinionDocument {
  id             String            @id @default(cuid())
  case           SecondOpinionCase @relation(fields: [caseId], references: [id])
  caseId         String
  type           String // EPICRISIS | IMAGING | PATHOLOGY | MEDICATION_LIST
  deliveryMethod String // FILE_UPLOAD | EXTERNAL_LINK
  fileRef        String? // base64 veri-URI (küçük dosya; object storage gelince değişir)
  externalRef    String? // DICOM / bulut linki (IMAGING)
  label          String? // dosya adı / açıklama
  uploadedBy     String // User.id
  uploadedAt     DateTime          @default(now())

  @@index([caseId])
}

/// Hasta talebi — Talep A (eksik belge) ve Talep B (ek tetkik) aynı varlığın iki tipi (§3.1/§6).
model SecondOpinionRequest {
  id          String            @id @default(cuid())
  case        SecondOpinionCase @relation(fields: [caseId], references: [id])
  caseId      String
  type        String // MISSING_DOCUMENT (Talep A) | ADDITIONAL_EXAMINATION (Talep B)
  description String
  requestedBy String // "coordinator" | "doctor"
  requestedById String? // işlemi açan User.id (audit)
  status      String            @default("PENDING") // PENDING | FULFILLED
  createdAt   DateTime          @default(now())
  fulfilledAt DateTime?

  @@index([caseId])
}

/// Yazılı ikinci görüş (§6). İçerik yapılandırılmış metin; çok dilli sunum Translation ile.
model SecondOpinion {
  id          String            @id @default(cuid())
  case        SecondOpinionCase @relation(fields: [caseId], references: [id])
  caseId      String            @unique
  doctorId    String
  content     String // yazılı görüş tam metni
  structured  String? // JSON bölümler (opsiyonel)
  attachments String?
  submittedAt DateTime          @default(now())
}

/// Video randevusu (§6). Görüşmeyi mevcut video altyapısı yürütür; burada yalnız randevu + referans.
model SecondOpinionAppointment {
  id               String            @id @default(cuid())
  case             SecondOpinionCase @relation(fields: [caseId], references: [id])
  caseId           String            @unique
  patientId        String
  doctorId         String
  scheduledAt      DateTime
  externalVideoRef String? // mevcut video altyapısına referans (Consultation.id) — Faz 4
  status           String            @default("SCHEDULED") // SCHEDULED | COMPLETED | CANCELLED
  createdAt        DateTime          @default(now())
}

/// Peşin ödeme (§6/§11). 600 USD tek ödeme; kart verisi modülde TUTULMAZ. Şimdilik simüle
/// (gerçek gateway TODO). İade politikası PARK (§9.1) → REFUNDED durumu ileride kullanılır.
model SecondOpinionPayment {
  id          String            @id @default(cuid())
  case        SecondOpinionCase @relation(fields: [caseId], references: [id])
  caseId      String            @unique
  amount      Int               @default(600) // USD (§11)
  currency    String            @default("USD")
  status      String            @default("PENDING") // PENDING | PAID | REFUNDED | FAILED
  providerRef String? // simüle ödeme referansı
  paidAt      DateTime?
  createdAt   DateTime          @default(now())
}

/// Denetim izi (§8) — her durum geçişi + belge erişimi (kim/ne zaman). Spec'in çekirdek
/// varlıkları arasında yok ama §8 NFR'si zorunlu kılıyor → eklendi.
model SecondOpinionEvent {
  id        String            @id @default(cuid())
  case      SecondOpinionCase @relation(fields: [caseId], references: [id])
  caseId    String
  actorId   String? // işlemi yapan (User.id); sistem ise null
  actorRole String?
  action    String // STATUS_CHANGE | DOC_UPLOAD | DOC_VIEW | REQUEST_OPEN | REQUEST_FULFILL | OPINION_SUBMIT | PAYMENT | ASSIGN | VIDEO
  detail    String? // ör. "DRAFT→AWAITING_PAYMENT"
  createdAt DateTime          @default(now())

  @@index([caseId])
}

/// Değiştirilemez erişim denetim kaydı (E2EE Faz 0 — "sıkı erişim kontrolü + audit").
/// Klinik veriye her ANLAMLI erişim (okuma/yazma/dışa aktarım) burada mühürlenir: kim/ne zaman/hangi kayıt.
/// v2.72 onam deseni birebir: append-only hash-zinciri (prevHash→entryHash) + (test) RFC 3161 zaman damgası.
/// Yüksek-frekanslı mekanik olaylar (signal polling, i18n, notifications) KASITLI dışarıda (flood önleme).
/// Mevcut tablolara dokunmaz → gevşek String bağlar (FK yok). lib/audit.ts ile yazılır/doğrulanır.
model AccessLog {
  id            String    @id @default(cuid())
  actorId       String? // erişen kullanıcı (User.id); sistem ise null
  actorRole     String? // erişim anındaki rol (snapshot)
  action        String // CASE_VIEW | CONSULT_WRITE | CONSULT_END | FHIR_EXPORT | DOCUMENT_VIEW ...
  resourceType  String // CASE | CONSULTATION | FHIR_COMPOSITION | FHIR_CONSENT | CASE_DOCUMENT ...
  resourceId    String // erişilen kaydın id'si
  subjectUserId String? // verinin sahibi hasta (User.id) — "verime kim erişti" görünümü için
  detail        String? // ek bağlam (alan / uç nokta)
  ip            String?
  userAgent     String?
  createdAt     DateTime  @default(now())
  // İspat & bütünlük (v2.72 deseni): append-only hash-zinciri + (test) RFC 3161 zaman damgası
  prevHash    String? // önceki kaydın entryHash'i (GENESIS = ilk)
  entryHash   String? // SHA-256(actorId|action|resourceType|resourceId|subjectUserId|createdAt|prevHash) — bu kaydın mührü
  tsAuthority String? // zaman damgası otoritesi (şimdilik SIMULATED-LOCAL)
  tsTime      DateTime? // TSA'nın güvenilir zamanı
  tsToken     String? // imzalı zaman damgası token'ı (entryHash üzerinde)

  @@index([subjectUserId, createdAt])
  @@index([resourceType, resourceId])
  @@index([actorId])
}
